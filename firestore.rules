rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 확인 함수
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == 'admin@cafebook.com'); // 초기 관리자 예시
    }

    // 카페 정보: 누구나 읽기 가능, 관리자만 생성/삭제 가능.
    // imageUrl 필드 및 통계 필드(averageRating, totalRatings, favoriteCount)는 누구나 업데이트 가능 (캐싱 및 집계 목적)
    match /cafes/{cafeId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl', 'averageRating', 'totalRatings', 'favoriteCount']);
    }

    // 상호작용(리뷰): 누구나 읽기 가능, 인증된 사용자만 자신의 것 쓰기 가능
    // interactionId는 {userId}_{cafeId} 형식이므로 split('_')[0]으로 사용자 본인 확인
    match /interactions/{interactionId} {
      allow read: if true;
      allow write: if request.auth != null && interactionId.split('_')[0] == request.auth.uid;
    }

    // 사용자 정보: 본인 또는 관리자만 접근 가능
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}

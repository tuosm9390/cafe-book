rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 확인 함수
    function isAdmin() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == 'admin@cafebook.com'); // 초기 관리자 예시
    }

    // 카페 정보: 누구나 읽기 가능, 관리자만 생성/삭제 가능.
    match /cafes/{cafeId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['imageUrl', 'averageRating', 'totalRatings', 'favoriteCount', 'updatedAt']);
    }

    // 상호작용(리뷰): 누구나 읽기 가능, 인증된 사용자만 자신의 것 쓰기 가능
    match /interactions/{interactionId} {
      allow read: if true;
      allow write: if request.auth != null && interactionId.split('_')[0] == request.auth.uid;
    }

    // 사용자 정보: 본인 또는 관리자만 접근 가능
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 레시피 정보: 인증된 사용자만 가능, 본인 데이터만 CRUD 가능
    match /recipes/{recipeId} {
      allow read: if request.auth != null; // 목록 및 상세 조회를 위해 읽기는 허용 (또는 본인 것만 보게 하려면 uid 비교 추가)
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
